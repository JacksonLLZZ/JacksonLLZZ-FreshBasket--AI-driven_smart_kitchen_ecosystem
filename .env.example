# API 配置示例文件
# 复制此文件为 api_config.dart 并填入实际的 API keys

# ===========================
# Edamam API 凭据
# ===========================
# 注册地址：https://developer.edamam.com/
# 用于：营养信息查询
EDAMAM_APP_ID=your_edamam_app_id_here
EDAMAM_APP_KEY=your_edamam_app_key_here

# ===========================
# Spoonacular API 凭据
# ===========================
# 注册地址：https://spoonacular.com/food-api
# 用于：食谱搜索和营养分析
SPOONACULAR_API_KEY=your_spoonacular_api_key_here

# ===========================
# 百度 AI 凭据
# ===========================
# 注册地址：https://ai.baidu.com/
# 用于：图像识别等功能
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET_KEY=your_baidu_secret_key_here

# ===========================
# 百度翻译 API 凭据
# ===========================
# 注册地址：http://api.fanyi.baidu.com/
# 用于：多语言翻译
BAIDU_TRANSLATE_APP_ID=your_baidu_translate_app_id_here
BAIDU_TRANSLATE_SECRET_KEY=your_baidu_translate_secret_key_here

# ===========================
# Google Gemini API 密钥
# ===========================
# 注册地址：https://makersuite.google.com/app/apikey
# 用于：AI 生成内容（由用户在设置中配置）
# 注意：此 API key 由用户通过应用设置界面输入，存储在 SharedPreferences 中
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================
# Firebase 配置
# ===========================
# Firebase 配置由 FlutterFire CLI 自动生成在 lib/firebase_options.dart
# 无需在此文件中配置
